{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/weather", "dest": "/api/weather.js" },
    { "src": "/api/forecast", "dest": "/api/forecast.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
