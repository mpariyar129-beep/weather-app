{
  "version": 2,
  "builds": [
    {
      "src": "weather.js",
      "use": "@vercel/node"
    },
    {
      "src": "forecast.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/weather",
      "dest": "/weather.js"
    },
    {
      "src": "/forecast",
      "dest": "/forecast.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
